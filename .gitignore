# DrugBank source data — academic license prohibits redistribution.
# We ignore data/ contents rather than the directory itself so the
# !exceptions below can re-include specific small artifacts.
/data/*
!/data/.gitkeep
# Exception — tracked because it's COPY'd into the image build
# (see Dockerfile.api). Placeholder ``{}`` is committed; real content
# is regenerated via ``python -m scripts.seed_demo`` pre-deploy.
!/data/demo_responses.json
*.xml
*.xml.zip
*.xml.gz

# DrugBank-derived artifacts (also covered by license)
chroma_db/
gazetteer.pkl
*.pkl
etl/out/
*.jsonl

# Environment / secrets
.env
.env.local
*.secret

# MLflow runs (may contain query traces with drug data)
mlruns/

# Standard Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenv
venv/
.venv/

# IDE / Claude Code project context (local-only)
.vscode/
.idea/
.claude/
CLAUDE.md
CLAUDE_CODE_MASTER_PROMPT.md
CLAUDE_CODE_STEP_PROMPTS.md

# OS
.DS_Store
Thumbs.db
