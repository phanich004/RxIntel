NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Groq (router default; reasoning/critic also when ROUTER_PROVIDER=groq)
GROQ_API_KEY=gsk_
GROQ_MIN_DELAY_MS=200

# Anthropic (reasoning + critic always; router when ROUTER_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-

# Per-node model strings. Reasoning/critic moved to Anthropic in commit
# 8d4db54; router stays on Groq by default but can be swapped per
# ROUTER_PROVIDER below.
REASONING_MODEL=claude-sonnet-4-6
CRITIC_MODEL=claude-sonnet-4-6
ROUTER_MODEL=llama-3.3-70b-versatile

# Router provider switch. Default "groq" (production). Set "anthropic"
# during benchmarks if Groq's free-tier TPD is exhausted; ROUTER_MODEL_ANTHROPIC
# names the Claude model for that path.
ROUTER_PROVIDER=groq
ROUTER_MODEL_ANTHROPIC=claude-sonnet-4-6

MAX_RETRIES=3
CRITIC_APPROVAL_THRESHOLD=0.75
INSUFFICIENT_EVIDENCE_COSINE=0.60
CHROMA_PERSIST_DIR=./chroma_db
GAZETTEER_PATH=./gazetteer.pkl
# Host port 5001 because macOS AirPlay Receiver squats on 5000.
MLFLOW_TRACKING_URI=http://localhost:5001
